# Copy this file to .env and fill in your values.
# .env is already in .gitignore, so your secrets stay safe.

# ----- Agent Identity -----
# The display name shown in the agent's responses.
AGENT_NAME="Abdullah's Copilot Agent"

# System prompt: tells the AI who it is, what it knows, and how to behave.
# You can add any custom knowledge here (e.g., your project rules, preferred stack, etc.)
SYSTEM_PROMPT="You are Abdullah's Copilot Agent, a helpful GitHub Copilot Extension. You assist developers with coding questions, project guidance, and best practices. Always be concise, friendly, and helpful."

# ----- Server -----
PORT=3000

# ----- AI Model (choose one) -----

# Option A: OpenAI API key (get yours at https://platform.openai.com/api-keys)
# When running locally without a GitHub Copilot token, this is used as a fallback.
OPENAI_API_KEY=

# Model to use when calling OpenAI directly (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Model to use via the GitHub Copilot LLM proxy (default: gpt-4o)
# The proxy uses the X-GitHub-Token that Copilot sends automatically — no extra key needed.
COPILOT_MODEL=gpt-4o
