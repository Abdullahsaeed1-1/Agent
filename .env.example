# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# (Optional) OpenAI model to use. Defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# (Optional) System prompt that shapes the assistant's personality
SYSTEM_PROMPT=You are a helpful AI assistant integrated into GitHub Copilot. Answer clearly and concisely.

# (Optional) Number of conversation turns to remember per session. Defaults to 10
MEMORY_SIZE=10

# (Optional) Port the server listens on. Defaults to 3000
PORT=3000
