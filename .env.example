# Port the agent server listens on (default: 3000)
PORT=3000

# Display name of your agent (used in responses and logs)
AGENT_NAME=Abdullah-Agent

# OpenAI API key — get yours at https://platform.openai.com/api-keys
# Leave empty to run in echo/demo mode (no real AI)
OPENAI_API_KEY=

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
